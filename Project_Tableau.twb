      <column caption='Quantity KPI' datatype='string' name='[Calculation_1256785771119759362]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Quantity]) &gt;= 12000 THEN &quot;GOOD&quot;&#13;&#10;ELSE &quot;NOT GOOD&quot;&#13;&#10;END' />
      </column>
      <column caption='profit' datatype='real' name='[Calculation_1951184538846781441]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Profit Margin]*[Quantity]' />
      </column>
      <column caption='Avg Delivery Time' datatype='real' name='[Calculation_1951184538864668681]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ROUND(AVG([Delivery Time (Days)]))' />
      </column>
      <column caption='Sales' datatype='real' name='[Calculation_2230689258844319744]' role='measure' type='quantitative'>
